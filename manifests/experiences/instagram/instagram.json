{
  "title": "Instagram",
  "icon": "instagram.png",
  "dataPortal": "https://help.instagram.com/196883487377501",
  "data": ["test-instagram.zip"],
  "hideSummary": true,
  "hideFileExplorer": true,
  "files": {
    "comments": "**/comments.json",
    "connections": "**/connections.json",
    "contacts": "**/contacts.json",
    "likes": "**/likes.json",
    "media": "**/media.json",
    "messages": "**/messages.json",
    "profile": "**/profile.json",
    "saved": "**/saved.json",
    "searches": "**/searches.json",
    "settings": "**/settings.json"
  },
  "defaultView": [
    {
      "key": "comments",
      "sql": "comments",
      "files": ["comments"],
      "showTable": true,
      "title": "Comments",
      "text": "Comments recieved"
    }, 
    {
      "key": "connections",
      "sql": "connections",
      "files": ["connections"],
      "showTable": true,
      "title": "Connections",
      "text": "Connections to other users or hashtags"
    }, 
    {
      "key": "contacts",
      "sql": "contacts",
      "files": ["contacts"],
      "showTable": true,
      "title": "Contacts",
      "text": "Not implemented for lack of test data"
    }, 
    {
      "key": "likes",
      "sql": "likes",
      "files": ["likes"],
      "showTable": true,
      "title": "Likes",
      "text": ""
    }, 
    {
      "key": "photos",
      "sql": "photos",
      "files": ["media"],
      "showTable": true,
      "title": "Photos",
      "text": ""
    }, 
    {
      "key": "messages",
      "sql": "messages",
      "files": ["messages"],
      "showTable": true,
      "title": "Messages",
      "text": ""
    }, 
    {
      "key": "savedcollections",
      "sql": "savedcollections",
      "files": ["saved"],
      "showTable": true,
      "title": "Saved Collections",
      "text": ""
    }, 
    {
      "key": "searches",
      "sql": "searches",
      "files": ["searches"],
      "showTable": true,
      "title": "Searches",
      "text": "Queries you have issued to the search engine of Instagram"
    }
  ],
  "databaseConfig": {
    "tables": [
      {
        "name": "InstagramComment",
        "columns": [
          ["datetime", "TEXT"],
          ["text", "TEXT"],
          ["sender", "TEXT"]
        ]
      }, 
      {
        "name": "InstagramConnection",
        "columns": [
          ["datetime", "TEXT"],
          ["name", "TEXT"],
          ["type", "TEXT"]
        ]
      }, 
      {
        "name": "InstagramLike",
        "columns": [
          ["datetime", "TEXT"],
          ["name", "TEXT"],
          ["type", "TEXT"]
        ]
      }, 
      {
        "name": "InstagramPhoto", 
        "columns": [
          ["caption", "TEXT"],
          ["datetime", "TEXT"],
          ["location", "TEXT"],
          ["path", "TEXT"]
        ]
      }, 
      {
        "name": "InstagramMessage", 
        "columns": [
          ["sender", "TEXT"],
          ["datetime", "TEXT"],
          ["text", "TEXT"]
        ]
      }, 
      {
        "name": "InstagramSavedCollection", 
        "columns": [
          ["collectionName", "TEXT"],
          ["mediaUserName", "TEXT"],
          ["mediaDateTime", "TEXT"]
        ]
      }, 
      {
        "name": "InstagramSearch", 
        "columns": [
          ["searchClick", "TEXT"],
          ["time", "TEXT"],
          ["type", "TEXT"]
        ]
      }      
    ],
    "getters": [
      {
        "fileId": "comments",
        "path": "$.media_comments[*]",
        "table": "InstagramComment",
        "getters": [
          {
            "column": "datetime",
            "path": "$.[0]"
          },
          {
            "column": "text",
            "path": "$.[1]"
          },
          {
            "column": "sender",
            "path": "$.[2]"
          }
        ]
      }, 
      {
        "fileId": "connections",
        "path": "$..[*]@string()",
        "table": "InstagramConnection",
        "options": {
          "resultType": "all",
          "callback": "value => value.grandparentProperty = value.pointer.split('/')[1]"
        },
        "getters": [
          {
            "column": "type",
            "path": "$.grandparentProperty"
          },
          {
            "column": "name",
            "path": "$.parentProperty"
          },
          {
            "column": "datetime",
            "path": "$.value"
          }
        ]
      }, 
      {
        "fileId": "likes",
        "path": "$.[*].[*]@array()",
        "table": "InstagramLike",
        "options": {
          "resultType": "all",
          "callback": "value => value.grandparentProperty = value.pointer.split('/')[1]"
        },
        "getters": [
          {
            "column": "type",
            "path": "$.grandparentProperty"
          },
          {
            "column": "name",
            "path": "$.value[1]"
          },
          {
            "column": "datetime",
            "path": "$.value[0]"
          }
        ]
      }, 
      {
        "fileId": "media",
        "path": "$.photos[*]",
        "table": "InstagramPhoto",
        "getters": [
          {
            "column": "caption",
            "path": "$.caption"
          },
          {
            "column": "datetime",
            "path": "$.['taken_at']"
          },
          {
            "column": "location",
            "path": "$.['location']"
          },
          {
            "column": "path",
            "path": "$.['path']"
          }
        ]
      },
      {
        "fileId": "messages",
        "path": "$[*].conversation[*]",
        "table": "InstagramMessage",
        "getters": [
          {
            "column": "sender",
            "path": "$.sender"
          },
          {
            "column": "datetime",
            "path": "$.['created_at']"
          },
          {
            "column": "text",
            "path": "$.text"
          }
        ]
      },
      {
        "fileId": "saved",
        "path": "$.saved_collections[*].media[*]",
        "table": "InstagramSavedCollection",
        "options": {
          "resultType": "all",
          "callback": "output => output.namePath = output.path.split(\"['media']\")[0] + \"['name']\""
          },
        "getters": [
          {
            "column": "collectionName",
            "pathKey": "namePath",
            "queryRoot": true
          },
          {
            "column": "mediaUserName",
            "path": "$.value[1]"
          },
          {
            "column": "mediaDateTime",
            "path": "$.value[0]"
          }
        ]
      }, 
      {
        "fileId": "searches",
        "path": "$.[*]",
        "table": "InstagramSearch",
        "getters": [
          {
            "column": "searchClick",
            "path": "$.['search_click']"
          },
          {
            "column": "time",
            "path": "$.time"
          },
          {
            "column": "type",
            "path": "$.type"
          }
        ]
      }
    ]
  }
}
