{
  "title": "Instagram",
  "icon": "instagram.png",
  "dataPortal": "https://help.instagram.com/196883487377501",
  "data": ["test-instagram.zip"],
  "hideSummary": true,
  "hideFileExplorer": true,
  "files": {
    "comments": "**/comments.json",
    "connections": "**/connections.json",
    "contacts": "**/contacts.json",
    "likes": "**/likes.json",
    "media": "**/media.json",
    "messages": "**/messages.json",
    "profile": "**/profile.json",
    "saved": "**/saved.json",
    "searches": "**/searches.json",
    "settings": "**/settings.json"
  },
  "defaultView": [
    {
      "key": "comments",
      "sql": "comments",
      "files": ["comments"],
      "showTable": true,
      "title": "Comments",
      "text": "Comments recieved"
    }, 
    {
      "key": "connections",
      "sql": "connections",
      "files": ["connections"],
      "showTable": true,
      "title": "Connections",
      "text": "Connections to other users or hashtags"
    }, 
    {
      "key": "contacts",
      "sql": "contacts",
      "files": ["contacts"],
      "showTable": true,
      "title": "Contacts",
      "text": "Not implemented for lack of test data"
    }, 
    {
      "key": "likes",
      "sql": "likes",
      "files": ["likes"],
      "showTable": true,
      "title": "Likes",
      "text": ""
    }
  ],
  "databaseConfig": {
    "tables": [
      {
        "name": "InstagramComment",
        "columns": [
          ["datetime", "TEXT"],
          ["text", "TEXT"],
          ["sender", "TEXT"]
        ]
      }, 
      {
        "name": "InstagramConnection",
        "columns": [
          ["datetime", "TEXT"],
          ["name", "TEXT"],
          ["type", "TEXT"]
        ]
      }, 
      {
        "name": "InstagramLike",
        "columns": [
          ["datetime", "TEXT"],
          ["name", "TEXT"],
          ["type", "TEXT"]
        ]
      }      
    ],
    "getters": [
      {
        "fileId": "comments",
        "path": "$.media_comments[*]",
        "table": "InstagramComment",
        "getters": [
          {
            "column": "datetime",
            "path": "$.[0]"
          },
          {
            "column": "text",
            "path": "$.[1]"
          },
          {
            "column": "sender",
            "path": "$.[2]"
          }
        ]
      }, 
      {
        "fileId": "connections",
        "path": "$..*[?(@.match(/^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}$/))]",
        "table": "InstagramConnection",
        "options": {
          "resultType": "all",
          "callback": "value => value.grandparentProperty = value.pointer.split('/')[1]"
        },
        "getters": [
          {
            "column": "type",
            "path": "$.grandparentProperty"
          },
          {
            "column": "name",
            "path": "$.parentProperty"
          },
          {
            "column": "datetime",
            "path": "$.value"
          }
        ]
      }, 
      {
        "fileId": "likes",
        "path": "$..*[?(@property.match(/^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}$/))]",
        "table": "InstagramLike",
        "options": {
          "resultType": "all",
          "callback": "value => value.grandparentProperty = value.pointer.split('/')[1]"
        },
        "getters": [
          {
            "column": "type",
            "path": "$.grandparentProperty"
          },
          {
            "column": "name",
            "path": "$.parentProperty"
          },
          {
            "column": "datetime",
            "path": "$.value"
          }
        ]
      }
    ]
  }
}
